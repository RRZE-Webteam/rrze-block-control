        extensions: [ '.tsx', '.ts', '.js', '.json' ],
    },
    plugins: [
        new RemoveEmptyScriptsPlugin({ extensions: /\.(css.js)$/ }),
        ...defaultConfig.plugins,
    ],
    optimization: {
        ...defaultConfig.optimization,
    },
    performance: { ...defaultConfig.performance, hints: false },
};